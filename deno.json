{
  "nodeModulesDir": "auto",
  "imports": {
    "react": "npm:react@^19.2.7",
    "react/jsx-runtime": "npm:react@^18.3.1/jsx-runtime",
    "react-dom": "npm:react-dom@^19.2.7",
    "react-dom/client": "npm:react-dom@^18.3.1/client",
    "mobx": "npm:mobx@^6.16.1",
    "mobx-react": "npm:mobx-react@^9.2.2",
    "vinxi": "npm:vinxi@^0.5.11",
    "vinxi/http": "npm:vinxi@^0.5.11/http",
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@^6.0.3",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.3.2",
    "tailwindcss": "npm:tailwindcss@^4.3.2",
    "@types/react": "npm:@types/react@^19.2.17",
    "@types/react-dom": "npm:@types/react-dom@^19.2.3",
    "@types/node": "npm:@types/node@^22.15.21",
    "vite": "npm:vite@^8.1.3",
    "fetch-to-node": "npm:fetch-to-node@^2.1.0"
  },
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "lib": ["ESNext", "DOM", "DOM.Iterable", "deno.ns"],
    "module": "ESNext"
  },
  "desktop": {
    "app": {
      "name": "Vinxi Desktop POC",
      "identifier": "com.test.vinxi-desktop"
    },
    "output": {
      "macos": "./dist/vinxi-desktop.app"
    }
  }
}
